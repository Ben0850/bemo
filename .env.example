# ===== Bemo-Verwaltung Environment Config =====

# App
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Nginx Ports (host-seitig)
HTTP_PORT=80
HTTPS_PORT=443

# Domain (für Let's Encrypt SSL)
DOMAIN=app.bemo-autovermietung.de
CERT_EMAIL=info@bemo-autovermietung.de

# S3 Object Storage (Hetzner)
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BUCKET=regiohz01-bpapp
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=nbg1
